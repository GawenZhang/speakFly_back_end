# Django
DJANGO_SECRET_KEY=your-secret-key
DJANGO_DEBUG=True
ALLOWED_HOSTS=speakfly.cn,www.speakfly.cn,127.0.0.1
# 生产环境 Nginx 已配置 HTTPS 时设为 true（强制跳转、安全 Cookie）
# DJANGO_USE_HTTPS=true
# DJANGO_DEBUG=False
# 可选：限制 CORS 来源（逗号分隔），不填则允许所有
# CORS_ALLOWED_ORIGINS=https://speakfly.cn,https://www.speakfly.cn

# MySQL（配置后使用 MySQL，不配置则使用 SQLite）
MYSQL_NAME=speakfly
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# 阿里云 OSS（图片/视频/音频上传到 OSS，数据库只存 URL）
OSS_ACCESS_KEY_ID=你的AccessKeyId
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret
OSS_BUCKET_NAME=speakfly-videos
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# 可选：自定义域名，用于返回文件访问 URL（如 cdn.example.com）
OSS_BUCKET_DOMAIN=
# 可选：存储目录前缀，默认 speakfly
OSS_UPLOAD_DIR=speakfly
